// NexusAI Service Worker — Offline Support
const CACHE_NAME = 'nexusai-v1.0';
const ASSETS = [
  '/',
  '/index.html',
  '/style.css',
  '/app.js',
  '/manifest.json',
  'https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap',
];

// Install — cache all assets
self.addEventListener('install', (event) => {
  self.skipWaiting();
  event.waitUntil(
    caches.open(CACHE_NAME).then(cache => {
      return Promise.allSettled(
        ASSETS.map(url => cache.add(url).catch(() => {}))
      );
    })
  );
});

// Activate — clean old caches
self.addEventListener('activate', (event) => {
  clients.claim();
  event.waitUntil(
    caches.keys().then(keys =>
      Promise.all(keys.filter(k => k !== CACHE_NAME).map(k => caches.delete(k)))
    )
  );
});

// Fetch — cache first for assets, network first for API
self.addEventListener('fetch', (event) => {
  const url = new URL(event.request.url);

  // API calls — always network, never cache
  if (url.hostname === 'api.anthropic.com' || url.pathname.includes('/v1/')) {
    event.respondWith(
      fetch(event.request).catch(() =>
        new Response(JSON.stringify({
          error: { message: 'لا يوجد اتصال بالإنترنت. يعمل NexusAI في الوضع المحلي.' }
        }), { headers: { 'Content-Type': 'application/json' } })
      )
    );
    return;
  }

  // Google Fonts — cache first
  if (url.hostname.includes('fonts.')) {
    event.respondWith(
      caches.match(event.request).then(cached => cached || fetch(event.request).then(res => {
        const clone = res.clone();
        caches.open(CACHE_NAME).then(c => c.put(event.request, clone));
        return res;
      }))
    );
    return;
  }

  // App assets — cache first, fallback to index.html
  event.respondWith(
    caches.match(event.request).then(cached => {
      if (cached) return cached;
      return fetch(event.request).then(res => {
        if (res.ok) {
          const clone = res.clone();
          caches.open(CACHE_NAME).then(c => c.put(event.request, clone));
        }
        return res;
      }).catch(() => caches.match('/index.html'));
    })
  );
});

// Background sync for cloud saves
self.addEventListener('sync', (event) => {
  if (event.tag === 'cloud-sync') {
    event.waitUntil(doCloudSync());
  }
});

async function doCloudSync() {
  // Sync pending data when back online
  console.log('NexusAI: Background sync triggered');
}
/* === NEXUSAI STYLES === */
:root {
  --bg: #0a0a0f;
  --bg2: #111118;
  --bg3: #1a1a26;
  --border: rgba(124,58,237,0.2);
  --border2: rgba(124,58,237,0.4);
  --primary: #7c3aed;
  --primary-light: #a78bfa;
  --cyan: #06b6d4;
  --text: #e2e8f0;
  --text-dim: #94a3b8;
  --text-muted: #475569;
  --success: #10b981;
  --error: #ef4444;
  --warning: #f59e0b;
  --radius: 14px;
  --radius-sm: 8px;
  --shadow: 0 0 30px rgba(124,58,237,0.15);
  --font: 'IBM Plex Sans Arabic', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}
[data-theme="light"] {
  --bg: #f0f0f8; --bg2: #ffffff; --bg3: #e8e8f8;
  --text: #1e1e2e; --text-dim: #4a4a6a; --text-muted: #8888aa;
  --border: rgba(124,58,237,0.15); --border2: rgba(124,58,237,0.3);
}
[data-theme="deep"] {
  --bg: #00001a; --bg2: #00002a; --bg3: #00003a;
  --primary: #6d28d9; --cyan: #0891b2;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; overflow: hidden; font-family: var(--font); background: var(--bg); color: var(--text); direction: rtl; }

/* === SPLASH === */
.splash {
  position: fixed; inset: 0; z-index: 9999;
  background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column;
}
.splash-orb {
  position: absolute; width: 300px; height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(124,58,237,0.3) 0%, transparent 70%);
  animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1);opacity:0.6} 50%{transform:scale(1.2);opacity:1} }
.splash-content { position: relative; text-align: center; z-index: 1; }
.splash-logo { margin-bottom: 16px; animation: float 3s ease-in-out infinite; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.splash-title {
  font-size: 2.5rem; font-weight: 700; letter-spacing: 2px;
  background: linear-gradient(135deg, #a78bfa, #06b6d4);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.splash-sub { color: var(--text-dim); margin: 8px 0 24px; font-size: 0.9rem; }
.splash-loader { width: 200px; height: 3px; background: var(--bg3); border-radius: 99px; overflow: hidden; margin: 0 auto 12px; }
.loader-bar {
  height: 100%; width: 0%;
  background: linear-gradient(90deg, #7c3aed, #06b6d4);
  border-radius: 99px;
  animation: load 2.5s ease-out forwards;
}
@keyframes load { to { width: 100%; } }
.splash-status { color: var(--text-muted); font-size: 0.8rem; }

/* === LAYOUT === */
.app { display: flex; height: 100vh; width: 100vw; overflow: hidden; }
.hidden { display: none !important; }

/* === SIDEBAR === */
.sidebar {
  position: fixed; right: -280px; top: 0; bottom: 0; width: 280px; z-index: 100;
  background: var(--bg2);
  border-left: 1px solid var(--border);
  display: flex; flex-direction: column;
  transition: right 0.3s cubic-bezier(0.4,0,0.2,1);
  overflow-y: auto;
}
.sidebar.open { right: 0; }
.sidebar::-webkit-scrollbar { width: 3px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }
.sidebar::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 99px; }
.sidebar-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px; border-bottom: 1px solid var(--border);
}
.app-logo-mini { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 1.1rem; color: var(--primary-light); }
.close-sidebar { background: none; border: none; color: var(--text-dim); font-size: 1.1rem; cursor: pointer; padding: 4px 8px; border-radius: var(--radius-sm); }
.close-sidebar:hover { background: var(--bg3); }

.new-chat-btn {
  margin: 12px; padding: 10px 16px;
  background: linear-gradient(135deg, var(--primary), var(--cyan));
  border: none; border-radius: var(--radius); color: white;
  font-size: 0.9rem; font-family: var(--font); font-weight: 600;
  cursor: pointer; display: flex; align-items: center; gap: 8px;
  transition: opacity 0.2s, transform 0.1s;
}
.new-chat-btn:active { transform: scale(0.97); opacity: 0.9; }

.sidebar-section-title { padding: 8px 16px; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; }

.mode-list { padding: 4px 12px; display: flex; flex-direction: column; gap: 2px; }
.mode-btn {
  background: none; border: none; padding: 9px 12px; border-radius: var(--radius-sm);
  text-align: right; color: var(--text-dim); cursor: pointer; font-size: 0.88rem;
  font-family: var(--font); transition: all 0.2s; display: flex; align-items: center; gap: 8px;
}
.mode-btn:hover, .mode-btn.active { background: rgba(124,58,237,0.15); color: var(--primary-light); }

.history-list { padding: 4px 12px; flex: 1; overflow-y: auto; }
.history-item {
  padding: 8px 10px; border-radius: var(--radius-sm); cursor: pointer;
  font-size: 0.82rem; color: var(--text-dim); white-space: nowrap; overflow: hidden;
  text-overflow: ellipsis; transition: background 0.2s;
}
.history-item:hover { background: var(--bg3); color: var(--text); }
.no-history { color: var(--text-muted); font-size: 0.8rem; padding: 8px 4px; }

.memory-stats { padding: 8px 16px; }
.stat-item { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; color: var(--text-dim); padding: 3px 0; }
.stat-item span:first-child { font-size: 1rem; }

.sidebar-footer { padding: 12px; border-top: 1px solid var(--border); margin-top: auto; }
.settings-btn {
  width: 100%; padding: 8px; background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius-sm); color: var(--text-dim); cursor: pointer;
  font-family: var(--font); font-size: 0.85rem; margin-bottom: 8px;
  transition: all 0.2s;
}
.settings-btn:hover { background: rgba(124,58,237,0.15); color: var(--primary-light); border-color: var(--border2); }
.status-indicator { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; color: var(--text-muted); }
.status-dot { width: 8px; height: 8px; border-radius: 50%; }
.status-dot.online { background: var(--success); box-shadow: 0 0 6px var(--success); }
.status-dot.offline { background: var(--error); }

.overlay {
  position: fixed; inset: 0; z-index: 99;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(2px);
  transition: opacity 0.3s;
}

/* === MAIN === */
.main { flex: 1; display: flex; flex-direction: column; width: 100%; overflow: hidden; position: relative; }

/* === TOPBAR === */
.topbar {
  display: flex; align-items: center; padding: 10px 14px; gap: 10px;
  background: var(--bg2); border-bottom: 1px solid var(--border);
  position: relative; z-index: 10; min-height: 54px;
}
.menu-btn {
  background: none; border: none; color: var(--text-dim); font-size: 1.3rem;
  cursor: pointer; padding: 4px 8px; border-radius: var(--radius-sm); transition: all 0.2s;
}
.menu-btn:hover { background: var(--bg3); color: var(--text); }
.topbar-center { flex: 1; display: flex; align-items: center; gap: 8px; justify-content: center; }
.mode-indicator { font-size: 0.85rem; font-weight: 600; color: var(--primary-light); }
.online-badge {
  display: flex; align-items: center; gap: 4px;
  background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3);
  border-radius: 99px; padding: 2px 8px; font-size: 0.72rem; color: var(--success);
}
.pulse-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--success); animation: blink 1.5s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.topbar-actions { display: flex; gap: 4px; }
.icon-btn {
  background: none; border: none; font-size: 1.1rem; cursor: pointer;
  padding: 6px 8px; border-radius: var(--radius-sm); transition: all 0.2s; color: var(--text-dim);
}
.icon-btn:hover { background: var(--bg3); }

/* === CHAT === */
.chat-area {
  flex: 1; overflow-y: auto; padding: 16px 14px;
  display: flex; flex-direction: column;
  scroll-behavior: smooth;
}
.chat-area::-webkit-scrollbar { width: 4px; }
.chat-area::-webkit-scrollbar-track { background: transparent; }
.chat-area::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

/* === WELCOME === */
.welcome-screen { text-align: center; padding: 20px 0 30px; flex-shrink: 0; }
.welcome-orb {
  width: 100px; height: 100px; margin: 0 auto 20px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(124,58,237,0.4) 0%, transparent 70%);
  position: relative;
  animation: pulse 4s ease-in-out infinite;
}
.welcome-orb::after {
  content: '🧠'; font-size: 2.5rem;
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
}
.welcome-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 8px; color: var(--primary-light); }
.welcome-sub { color: var(--text-dim); font-size: 0.88rem; margin-bottom: 24px; }
.capability-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 10px; max-width: 500px; margin: 0 auto;
}
.cap-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 16px 12px;
  cursor: pointer; transition: all 0.2s; text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
}
.cap-card:hover { border-color: var(--border2); background: rgba(124,58,237,0.08); transform: translateY(-2px); }
.cap-card:active { transform: scale(0.97); }
.cap-icon { font-size: 1.6rem; }
.cap-text { font-size: 0.82rem; color: var(--text-dim); font-weight: 500; }

/* === MESSAGES === */
.messages { display: flex; flex-direction: column; gap: 16px; flex: 1; }

.msg { display: flex; gap: 10px; animation: msgIn 0.3s ease; }
@keyframes msgIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

.msg-user { justify-content: flex-start; }
.msg-ai { justify-content: flex-start; flex-direction: row-reverse; }

.msg-avatar {
  width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 1rem;
  border: 1px solid var(--border2);
}
.msg-user .msg-avatar { background: rgba(124,58,237,0.2); }
.msg-ai .msg-avatar { background: rgba(6,182,212,0.2); }

.msg-bubble {
  max-width: calc(100% - 50px); padding: 12px 14px; border-radius: var(--radius);
  font-size: 0.9rem; line-height: 1.7; word-wrap: break-word;
}
.msg-user .msg-bubble {
  background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.25);
  border-top-right-radius: 4px;
}
.msg-ai .msg-bubble {
  background: var(--bg2); border: 1px solid var(--border);
  border-top-left-radius: 4px;
}

/* Code blocks */
.msg-bubble pre {
  background: #0d1117; border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-sm); padding: 12px; margin: 10px 0;
  overflow-x: auto; font-family: var(--mono); font-size: 0.8rem; line-height: 1.6;
  position: relative;
}
.msg-bubble code { font-family: var(--mono); font-size: 0.85em; color: #a78bfa; }
.msg-bubble pre code { color: #e2e8f0; }
.copy-code-btn {
  position: absolute; top: 6px; left: 6px;
  background: rgba(255,255,255,0.1); border: none; border-radius: 4px;
  color: #94a3b8; font-size: 0.7rem; padding: 2px 6px; cursor: pointer;
}
.copy-code-btn:hover { background: rgba(255,255,255,0.2); }

.msg-bubble h1,.msg-bubble h2,.msg-bubble h3 { margin: 12px 0 6px; color: var(--primary-light); font-size: 1rem; }
.msg-bubble ul,.msg-bubble ol { padding-right: 20px; margin: 8px 0; }
.msg-bubble li { margin: 4px 0; }
.msg-bubble strong { color: var(--cyan); font-weight: 600; }
.msg-bubble a { color: var(--cyan); text-decoration: underline; }
.msg-bubble hr { border: none; border-top: 1px solid var(--border); margin: 12px 0; }
.msg-bubble table { width: 100%; border-collapse: collapse; margin: 10px 0; font-size: 0.82rem; }
.msg-bubble th,.msg-bubble td { border: 1px solid var(--border); padding: 6px 10px; text-align: right; }
.msg-bubble th { background: var(--bg3); color: var(--primary-light); }

.msg-footer { display: flex; gap: 8px; margin-top: 6px; align-items: center; }
.msg-time { font-size: 0.7rem; color: var(--text-muted); }
.msg-action-btn {
  background: none; border: none; font-size: 0.75rem; color: var(--text-muted);
  cursor: pointer; padding: 2px 5px; border-radius: 4px; transition: all 0.2s;
}
.msg-action-btn:hover { background: var(--bg3); color: var(--text-dim); }

.thinking-indicator {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 14px; background: var(--bg2);
  border: 1px solid var(--border); border-radius: var(--radius);
  border-top-left-radius: 4px; font-size: 0.85rem; color: var(--text-dim);
}
.thinking-dots { display: flex; gap: 4px; }
.thinking-dots span {
  width: 6px; height: 6px; border-radius: 50%; background: var(--primary-light);
  animation: dot 1.4s ease-in-out infinite;
}
.thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
.thinking-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes dot { 0%,80%,100%{transform:scale(0.6);opacity:0.4} 40%{transform:scale(1);opacity:1} }

.search-status {
  background: rgba(6,182,212,0.08); border: 1px solid rgba(6,182,212,0.2);
  border-radius: var(--radius-sm); padding: 6px 10px; font-size: 0.78rem;
  color: var(--cyan); margin-top: 6px; display: flex; align-items: center; gap: 6px;
}

.memory-tag {
  display: inline-flex; align-items: center; gap: 4px;
  background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.2);
  border-radius: 99px; padding: 2px 8px; font-size: 0.72rem; color: var(--primary-light);
  margin-top: 6px;
}

/* === INPUT === */
.input-area {
  background: var(--bg2); border-top: 1px solid var(--border);
  padding: 10px 14px 12px; flex-shrink: 0;
}
.web-search-toggle {
  display: flex; gap: 12px; flex-wrap: wrap;
  margin-bottom: 8px;
}
.toggle-label {
  display: flex; align-items: center; gap: 6px;
  cursor: pointer; font-size: 0.78rem; color: var(--text-dim);
  user-select: none;
}
.toggle-slider {
  width: 32px; height: 18px; border-radius: 99px; background: var(--bg3);
  position: relative; transition: background 0.2s; flex-shrink: 0;
  border: 1px solid var(--border);
}
.toggle-label input { display: none; }
.toggle-label input:checked + .toggle-slider { background: var(--primary); }
.toggle-slider::after {
  content: ''; position: absolute; top: 2px; right: 2px;
  width: 12px; height: 12px; border-radius: 50%; background: white;
  transition: transform 0.2s;
}
.toggle-label input:checked + .toggle-slider::after { transform: translateX(-14px); }

.input-box {
  display: flex; gap: 8px; align-items: flex-end;
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 8px 8px 8px 12px;
  transition: border-color 0.2s;
}
.input-box:focus-within { border-color: var(--border2); box-shadow: 0 0 0 3px rgba(124,58,237,0.1); }
#userInput {
  flex: 1; background: none; border: none; outline: none;
  color: var(--text); font-size: 0.9rem; line-height: 1.5;
  font-family: var(--font); resize: none; max-height: 150px;
  overflow-y: auto; direction: rtl;
}
#userInput::placeholder { color: var(--text-muted); }
.input-actions { display: flex; gap: 4px; align-items: flex-end; flex-shrink: 0; }
.voice-btn {
  background: none; border: none; font-size: 1.2rem; cursor: pointer;
  padding: 6px; border-radius: var(--radius-sm); transition: all 0.2s; opacity: 0.7;
}
.voice-btn:hover { opacity: 1; background: var(--bg2); }
.voice-btn.listening { color: var(--error); animation: blink 0.8s ease-in-out infinite; }
.send-btn {
  background: linear-gradient(135deg, var(--primary), var(--cyan));
  border: none; border-radius: var(--radius-sm); padding: 8px 12px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; min-width: 38px; height: 38px;
}
.send-btn:hover { opacity: 0.9; transform: scale(1.05); }
.send-btn:active { transform: scale(0.95); }
.send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

.input-footer {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 4px; font-size: 0.7rem; color: var(--text-muted);
}

/* === MODAL === */
.modal {
  position: fixed; inset: 0; z-index: 200;
  display: flex; align-items: flex-end; justify-content: center;
}
.modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); }
.modal-content {
  position: relative; background: var(--bg2);
  border: 1px solid var(--border); border-radius: var(--radius) var(--radius) 0 0;
  width: 100%; max-width: 600px; max-height: 90vh;
  display: flex; flex-direction: column;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px; border-bottom: 1px solid var(--border);
}
.modal-header h2 { font-size: 1rem; font-weight: 600; }
.close-modal { background: none; border: none; color: var(--text-dim); font-size: 1.1rem; cursor: pointer; padding: 4px 8px; border-radius: 6px; }
.close-modal:hover { background: var(--bg3); }
.modal-body { padding: 16px 20px; overflow-y: auto; flex: 1; }
.modal-footer { padding: 12px 20px; border-top: 1px solid var(--border); }

.setting-group { margin-bottom: 18px; }
.setting-group label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: var(--text-dim); }
.setting-input {
  width: 100%; padding: 9px 12px; background: var(--bg3);
  border: 1px solid var(--border); border-radius: var(--radius-sm);
  color: var(--text); font-size: 0.88rem; font-family: var(--font); outline: none;
  transition: border-color 0.2s;
}
.setting-input:focus { border-color: var(--border2); }
.setting-hint { font-size: 0.74rem; color: var(--text-muted); margin-top: 4px; }
.slider { width: 100%; accent-color: var(--primary); }

.theme-picker { display: flex; gap: 8px; }
.theme-opt {
  flex: 1; padding: 8px; border: 1px solid var(--border); border-radius: var(--radius-sm);
  background: var(--bg3); color: var(--text-dim); cursor: pointer; font-size: 0.82rem;
  transition: all 0.2s; font-family: var(--font);
}
.theme-opt.active { border-color: var(--border2); background: rgba(124,58,237,0.15); color: var(--primary-light); }

.danger-btn, .export-btn, .install-btn {
  padding: 8px 14px; border-radius: var(--radius-sm); border: none;
  cursor: pointer; font-size: 0.85rem; font-family: var(--font); margin-left: 8px;
  transition: all 0.2s;
}
